# OpenRouter settings
OpenRouter__ApiKey=your_openrouter_api_key
OpenRouter__Referer=http://localhost
OpenRouter__Title=Architecture Analysis MCP Backend

# ASP.NET Core
ASPNETCORE_URLS=http://localhost:5000
ASPNETCORE_ENVIRONMENT=Development

# CORS: origens permitidas (separadas por vírgula). Em dev, padrão é localhost.
# AllowedOrigins=http://localhost:5173,http://localhost:6274,http://localhost:3000
# AllowedOrigins=https://seu-dominio.com,https://outro-dominio.com

# API Key (opcional). Se definida, todas as requisições devem incluir o header X-Api-Key.
# API_KEY=sua_chave_secreta_aqui
