# Backend ASP.NET Core
BACKEND_URL=http://localhost:5000
BACKEND_ENDPOINT=/api/architecture/analyze

# Se o backend estiver protegido por API Key (variável API_KEY no backend/.env),
# configure aqui o mesmo valor para o MCP server passar no header X-Api-Key.
BACKEND_API_KEY=sua_chave_secreta_aqui

# Modelo padrão do OpenRouter quando llm_model não é informado na chamada.
# Exemplos: openrouter/auto, openai/gpt-4o-mini, anthropic/claude-3.5-sonnet
DEFAULT_LLM_MODEL=openrouter/auto

# Logs detalhados via stderr (true/false)
DEBUG=false
