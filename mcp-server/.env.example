# MCP Server Configuration
MCP_SERVER_PORT=3000

# Backend ASP.NET Core
BACKEND_URL=http://localhost:5000
BACKEND_ENDPOINT=/api/architecture/analyze

# OpenRouter API (optional - can be set in frontend/MCP caller)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Supported Models from OpenRouter
# Examples: openrouter/auto, openai/gpt-4o-mini, anthropic/claude-3.5-sonnet, etc.
DEFAULT_LLM_MODEL=openrouter/auto

# Environment
NODE_ENV=development
DEBUG=architecture-analysis-mcp:*
