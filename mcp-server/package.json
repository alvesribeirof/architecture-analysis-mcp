{
  "name": "architecture-analysis-mcp",
  "version": "1.0.0",
  "description": "MCP Server for architectural analysis using OpenRouter and ASP.NET Core backend",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "start:inspector": "npx -y @modelcontextprotocol/inspector node dist/index.js",
    "dev": "node --loader ts-node/esm src/index.ts",
    "dev:inspector": "npx -y @modelcontextprotocol/inspector node --loader ts-node/esm src/index.ts",
    "dev:watch": "nodemon --watch src --exec node --loader ts-node/esm src/index.ts",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "axios": "^1.6.0",
    "dotenv": "^16.3.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.54.0",
    "nodemon": "^3.0.2",
    "ts-node": "^10.9.1",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
